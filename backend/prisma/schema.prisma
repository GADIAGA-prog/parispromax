// PARISPROMAX backend — Prisma schema.
// Dev uses SQLite (zero-config). For production switch `provider` to
// "postgresql" or "mysql" and update DATABASE_URL in .env (JSON columns can
// then become native Json instead of stringified text).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  phone         String         @unique
  country       String?        // ISO2 (bf, ci, sn, tg, bj, ne, gn, ml) for payments
  trialStartedAt DateTime?
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  payments      Payment[]
}

// One-time codes for phone login (OTP).
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  plan             String   @default("monthly")
  status           String   @default("inactive") // active | inactive | expired
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model Payment {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  provider      String   @default("cinetpay")
  transactionId String   @unique // our generated id sent to the PSP
  providerRef   String?  // id returned by the PSP
  amount        Int
  currency      String   @default("XOF")
  plan          String?  // plan id: daily | weekly | monthly | quarterly | annual
  method        String?  // card | orange-money | wave | mtn | moov
  status        String   @default("pending") // pending | success | failed | cancelled
  description   String?
  rawPayload    String?  // JSON string of the provider payload
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ---- Racing data + predictions (real success-rate tracking) ---------------

model Race {
  id          String       @id @default(cuid())
  externalId  String       @unique // e.g. geny course id "c1663633"
  track       String
  name        String
  date        String       // YYYY-MM-DD
  discipline  String?
  condition   String?
  distance    String?
  raw         String?      // JSON string of full race + horses (legacy/compat)
  nonPartants String?      // JSON array of scratched runner numbers, e.g. "[3,7]"
  createdAt   DateTime     @default(now())
  predictions Prediction[]
  result      Result?
  runners     Runner[]     // M1 — normalised per-horse rows (feeds the LTR model)
}

// M1 — One normalised row per horse per race. Critical fields are OPTIONAL with
// intelligent defaults so a partial scrape never blocks ingestion; the LTR
// pipeline (M2) queries these rows grouped by `raceId` (= the ranking group).
// NOTE: `musiqueParsed` uses the native Json type -> requires PostgreSQL
// (the production datasource; dev should also run Postgres via the M3 compose).
model Runner {
  id            String   @id @default(cuid())
  raceId        String
  race          Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  number        Int
  name          String
  jockeyName    String?
  trainerName   String?
  coteFloat     Float?                 // market odds (optional)
  coteOpen      Float?                 // opening odds (odds-trend feature)
  gains         Int?     @default(0)
  chrono        Float?                 // trot reduction (seconds), optional
  deferrage     String?                // D4 | DA | DP ... (trot)
  musiqueRaw    String?
  musiqueParsed Json?                  // { derniere_performance, taux_top3_recent, specialite_predominante, changement_annee }
  jockeyRating  Float    @default(50)  // imputation default until ActorStat resolves
  trainerRating Float    @default(50)
  finishPos     Int?                   // official arrival rank (LTR label)
  createdAt     DateTime @default(now())

  @@unique([raceId, number])
  @@index([raceId])
}

// M1 — Rolling jockey/trainer performance, used to IMPUTE a rating when a
// runner's actor is unknown/missing (Bayesian-shrunk toward a neutral 50).
model ActorStat {
  id        String   @id @default(cuid())
  kind      String   // 'jockey' | 'trainer'
  name      String
  runs      Int      @default(0)
  top3      Int      @default(0)
  rating    Float    @default(50) // 0-100
  updatedAt DateTime @updatedAt

  @@unique([kind, name])
  @@index([kind])
}

model Prediction {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id])
  topPicks  String   // JSON string: [{number,name,aiScore,rank}]
  createdAt DateTime @default(now())

  @@index([raceId])
}

model Result {
  id         String   @id @default(cuid())
  raceId     String   @unique
  race       Race     @relation(fields: [raceId], references: [id])
  winners    String   // JSON string: [4,7,1,9,3]
  predicted  Boolean  @default(false) // did our top pick land in the placed runners?
  createdAt  DateTime @default(now())
}
