# PARISPROMAX backend — environment variables.
# Copy to ".env" and fill in. Never commit the real .env.

# --- Server ---
PORT=4000
# Comma-separated allowed origins for CORS (mobile app uses none; admin uses this)
CORS_ORIGINS=http://localhost:4000

# --- Database (dev = SQLite file) ---
DATABASE_URL="file:./dev.db"
# Production example (PostgreSQL):
# DATABASE_URL="postgresql://user:pass@host:5432/parispromax"

# --- Auth ---
# OBLIGATOIRE hors dev (base non-SQLite) : le serveur refuse de démarrer sans.
JWT_SECRET=change-me-to-a-long-random-string
OTP_TTL_MINUTES=5
# DANGER : "true" renvoie le code OTP dans la réponse API (connexion possible
# avec n'importe quel numéro). Par défaut : activé seulement en dev SQLite,
# désactivé partout ailleurs. Ne mettre "true" qu'en dev/staging.
OTP_DEV_MODE=true

# --- SMS provider (OPTIONNEL — l'app se connecte par mot de passe, sans SMS) ---
# Utile seulement si vous réactivez l'OTP SMS un jour.
# SMS_PROVIDER=twilio  -> TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN + SMS_SENDER
#                         (numéro Twilio ou sender id alphanumérique).
# SMS_PROVIDER=orange  -> API SMS Orange (developer.orange.com, dispo Burkina) :
#                         ORANGE_CLIENT_ID + ORANGE_CLIENT_SECRET + ORANGE_SENDER
#                         (numéro dédié du contrat, ex. +226XXXXXXXX).
SMS_PROVIDER=
SMS_SENDER=ParisPromax
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SENDER=

# --- Payment provider selection ---
# 'fedapay' (default) or 'cinetpay'. If the chosen provider has no keys set,
# payments fall back to a local MOCK checkout (great for dev/testing).
PAYMENT_PROVIDER=fedapay
# Comma-separated providers to hide even if configured (e.g. during an outage).
# Example: PAYMENT_DISABLED=cinetpay
PAYMENT_DISABLED=

# --- FedaPay (https://fedapay.com) ---
# From your FedaPay dashboard (Workbench). Use the SECRET key (sk_...).
# Customer management is built into FedaPay; we key customers by a stable email
# derived from the phone when the user has none.
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_MODE=sandbox
# Webhook endpoint secret (Workbench -> Webhooks). Optional: we also re-verify
# every transaction against the FedaPay API before granting access.
FEDAPAY_WEBHOOK_SECRET=
# ISO2 country used for the customer phone number (bj, ci, tg, sn, ne, gn ...).
FEDAPAY_COUNTRY=bf

# --- CinetPay (new API: panel.cinetpay.net / api.cinetpay.net) ---
# Dashboard -> Ressources -> API & securite: the API Key (sk_test_.../sk_live_...)
# and the API password. The key prefix selects the environment (test vs live);
# no site_id is needed with the new API.
CINETPAY_API_KEY=
CINETPAY_API_PASSWORD=

# --- PayDunya (https://paydunya.com) ---
# From your PayDunya dashboard. In test mode use the test_private key + test
# token; in live mode use the live_private key + live token. Master key is the
# same for both. PAYDUNYA_MODE=test|live selects the API base URL.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# --- LigdiCash (https://ligdicash.com) — agrégateur mobile money UEMOA ---
# Depuis ton projet API LigdiCash (Marchand -> API) : la clé "Apikey" et le
# "Token" (utilisé comme Bearer). LIGDICASH_MODE=test|live choisit la base URL
# (test.ligdicash.com vs app.ligdicash.com). Devise supportée : XOF uniquement.
LIGDICASH_API_KEY=
LIGDICASH_TOKEN=
LIGDICASH_MODE=test

# --- FeexPay API v2 (https://app-v2.feexpay.me) — mobile money (UEMOA) ---
# Dashboard v2 -> menu "Développeurs" -> encart API :
#   * onglet "Identifiant"  -> FEEXPAY_SHOP_ID (ex. anw2CF9Uemm9EyH)
#   * onglet "Clé privée"   -> FEEXPAY_TOKEN
# Le bouton Test/Production (en bas à gauche du dashboard) détermine quelles
# clés sont affichées : utilisez les clés PRODUCTION pour encaisser réellement.
#
# ⚠️ La carte bancaire est momentanément indisponible chez FeexPay : seul le
# Mobile Money (Orange/Moov BF, MTN, Wave…) fonctionne, en paiement direct.
#
# Webhook à déclarer dans le dashboard FeexPay :
#   https://<PUBLIC_BASE_URL>/payments/feexpay/webhook
# (le backend re-vérifie chaque transaction via l'API avant d'activer l'accès,
# donc même sans webhook joignable l'app se met à jour par polling.)
FEEXPAY_SHOP_ID=
FEEXPAY_TOKEN=
FEEXPAY_MODE=LIVE
# Optionnel : surcharge de la base API (défaut https://api-v2.feexpay.me/api).
FEEXPAY_BASE_URL=
# Secret PARTAGÉ du webhook (à inventer, ce n'est PAS la clé privée FeexPay).
# Dashboard FeexPay -> Webhooks -> Type d'en-tête: Bearer, Valeur: ce secret.
# Le backend rejette alors tout appel de webhook sans cet en-tête (401).
FEEXPAY_WEBHOOK_SECRET=

# Public URL of THIS backend (the PSP calls our webhook here). Use an ngrok/tunnel
# URL in dev so CinetPay can reach you.
PUBLIC_BASE_URL=http://localhost:4000

# --- Subscription pricing (base) ---
SUB_PRICE_XOF=5000
SUB_PERIOD_DAYS=30

# --- Admin back-office ---
# Hors dev, /admin est DÉSACTIVÉ tant qu'ADMIN_PASSWORD n'est pas défini
# (les identifiants par défaut admin/admin ne sont jamais acceptés en prod).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- Cron (scheduled refresh of races + results) ---
# A long random secret. The GitHub Actions workflow calls
# POST /cron/refresh?token=CRON_TOKEN. Set the SAME value here (Render) and as a
# GitHub repo secret named CRON_TOKEN.
CRON_TOKEN=

# --- ML daemon (Python Learning-to-Rank pipeline in /ml) ---
# Bearer token the Python daemon uses to POST predictions to /ml/predictions.
# Falls back to CRON_TOKEN if left blank. Without either set, /ml/predictions
# rejects all requests (401).
ML_PUSH_TOKEN=

# --- Journaux hippiques nationaux (bouton "Journal" de l'app) ---
# La course PMU du jour de chaque pays est désignée AUTOMATIQUEMENT au scrape
# quotidien (course événement). Renseignez ici, une fois pour toutes, la page
# du journal du jour de chaque loterie nationale (elle sera jointe au pick).
JOURNAL_URL_BF=
JOURNAL_URL_CI=
JOURNAL_URL_SN=
JOURNAL_URL_TG=
JOURNAL_URL_BJ=
JOURNAL_URL_CG=

# --- Micro-service IA (FastAPI /predict) ---
# Jeton Bearer envoyé par le backend à l'IA. Doit être IDENTIQUE à la variable
# PPM_IA_TOKEN du service IA. Laisser vide = IA sans authentification (dev).
IA_TOKEN=
