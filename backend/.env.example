# PARISPROMAX backend — environment variables.
# Copy to ".env" and fill in. Never commit the real .env.

# --- Server ---
PORT=4000
# Comma-separated allowed origins for CORS (mobile app uses none; admin uses this)
CORS_ORIGINS=http://localhost:4000

# --- Database (dev = SQLite file) ---
DATABASE_URL="file:./dev.db"
# Production example (PostgreSQL):
# DATABASE_URL="postgresql://user:pass@host:5432/parispromax"

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
OTP_TTL_MINUTES=5
# In dev, OTP codes are returned in the API response & logged. Set to "false"
# only once a real SMS provider is wired.
OTP_DEV_MODE=true

# --- SMS provider (optional, for real OTP delivery) ---
# Leave blank in dev. Example providers: Twilio, Orange SMS API, etc.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=ParisPromax

# --- Payment provider selection ---
# 'fedapay' (default) or 'cinetpay'. If the chosen provider has no keys set,
# payments fall back to a local MOCK checkout (great for dev/testing).
PAYMENT_PROVIDER=fedapay
# Comma-separated providers to hide even if configured (e.g. during an outage).
# Example: PAYMENT_DISABLED=cinetpay
PAYMENT_DISABLED=

# --- FedaPay (https://fedapay.com) ---
# From your FedaPay dashboard (Workbench). Use the SECRET key (sk_...).
# Customer management is built into FedaPay; we key customers by a stable email
# derived from the phone when the user has none.
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_MODE=sandbox
# Webhook endpoint secret (Workbench -> Webhooks). Optional: we also re-verify
# every transaction against the FedaPay API before granting access.
FEDAPAY_WEBHOOK_SECRET=
# ISO2 country used for the customer phone number (bj, ci, tg, sn, ne, gn ...).
FEDAPAY_COUNTRY=bf

# --- CinetPay (https://cinetpay.com) — kept for easy switch-back ---
# Get these from your CinetPay merchant dashboard once your account is open.
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_MODE=sandbox
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# --- PayDunya (https://paydunya.com) ---
# From your PayDunya dashboard. In test mode use the test_private key + test
# token; in live mode use the live_private key + live token. Master key is the
# same for both. PAYDUNYA_MODE=test|live selects the API base URL.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test
# Public URL of THIS backend (the PSP calls our webhook here). Use an ngrok/tunnel
# URL in dev so CinetPay can reach you.
PUBLIC_BASE_URL=http://localhost:4000

# --- Subscription pricing (base) ---
SUB_PRICE_XOF=5000
SUB_PERIOD_DAYS=30

# --- Admin back-office ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- Cron (scheduled refresh of races + results) ---
# A long random secret. The GitHub Actions workflow calls
# POST /cron/refresh?token=CRON_TOKEN. Set the SAME value here (Render) and as a
# GitHub repo secret named CRON_TOKEN.
CRON_TOKEN=

# --- ML daemon (Python Learning-to-Rank pipeline in /ml) ---
# Bearer token the Python daemon uses to POST predictions to /ml/predictions.
# Falls back to CRON_TOKEN if left blank. Without either set, /ml/predictions
# rejects all requests (401).
ML_PUSH_TOKEN=
