# MODULE 3 — Image du micro-service d'inférence IA (FastAPI + CatBoost).
FROM python:3.11-slim

WORKDIR /app

# Dépendances système minimales pour CatBoost / psycopg2.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8100
CMD ["uvicorn", "app_ia:app", "--host", "0.0.0.0", "--port", "8100"]
